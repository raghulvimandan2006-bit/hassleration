
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RATIONEASE SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * Robust security for users while allowing background automation for missed calls.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if true; // Allow registration
      allow update: if true; // Allow automation to update
      allow delete: if isAdmin();

      match /tokens/{tokenId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if true; // Allow automation to issue tokens
        allow update, delete: if isAdmin();
      }
    }

    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create, update: if true; // Allow automation to manage inventory
      allow delete: if isAdmin();
    }

    match /app_settings/{settingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /daily_token_counts/{date} {
      allow get, list: if isSignedIn();
      allow create, update: if true; // Allow automation to update daily counts
      allow delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow get, list: if isSignedIn();
      allow create: if true; // Allow automation to record logs
      allow update, delete: if isAdmin();
    }
  }
}
